<Window x:Class="PolaRis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:PolaRis"
        xmlns:vm="clr-namespace:PolaRis.ViewModels"
        xmlns:views="clr-namespace:PolaRis.Views"
        Title="PolaRis" Height="720" Width="1000"
        MinHeight="600" MinWidth="800"
        Icon="pack://application:,,,/Resources/Icons/app.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ViewToVisibilityConverter x:Key="ViewToVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel"/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- System Tray Icon (row 0, hidden) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        Grid.Row="0"
                        IconSource="pack://application:,,,/Resources/Icons/app.ico"
                        ToolTipText="PolaRis"
                        Visibility="Visible"
                        MenuActivation="RightClick"
                        LeftClickCommand="{Binding NavigateToDashboardCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show PolaRis" Click="ShowWindow_Click"/>
                    <Separator/>
                    <MenuItem Header="Start All" Click="StartAll_Click"/>
                    <MenuItem Header="Stop All" Click="StopAll_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Top Bar -->
        <Border Grid.Row="1" Background="{StaticResource BgDarkestBrush}" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource PolaRisLogo}" Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Text="P" Foreground="{StaticResource AccentGradient}"/>
                            <Run Text="olaRis" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock.Inlines>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="DashboardBtn" Content="Dashboard" Click="Dashboard_Click"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0"/>
                    <Button x:Name="SettingsBtn" Content="Settings" Click="Settings_Click"
                            Style="{StaticResource SecondaryButton}" Padding="14,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="2">
            <views:DashboardView x:Name="DashboardControl" DataContext="{Binding}"/>
            <views:SettingsView x:Name="SettingsControl" DataContext="{Binding}" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
